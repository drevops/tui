<?xml version="1.0"?>
<ruleset name="custom">
    <description>Custom PHPCS standard.</description>

    <!-- Using Drupal coding standard as a base. -->
    <rule ref="Drupal">
        <!-- Translator::t() is this library's own translation function; its
             render-boundary calls translate consumer-declared labels, which are
             dynamic by design, so the Drupal literal-string sniff does not
             apply. -->
        <exclude name="Drupal.Semantics.FunctionT.NotLiteralString"/>
    </rule>
    <rule ref="DrevOps"/>
    <!-- Checks that the strict_types has been declared. -->
    <rule ref="Generic.PHP.RequireStrictTypes"/>

    <!-- Show sniff codes in all reports -->
    <arg value="s"/>
    <!-- Show progress of the run. -->
    <arg value="p"/>
    <arg name="colors"/>

    <file>src</file>
    <file>tests/phpunit</file>
    <file>playground</file>
    <file>translations</file>

    <!-- Allow long array lines in tests and in translation catalogs, whose
         source => translation pairs are single, unbreakable data lines. -->
    <rule ref="Drupal.Arrays.Array.LongLineDeclaration">
        <exclude-pattern>*.Test\.php</exclude-pattern>
        <exclude-pattern>*.TestCase\.php</exclude-pattern>
        <exclude-pattern>*.test</exclude-pattern>
        <exclude-pattern>translations/*</exclude-pattern>
    </rule>

    <!-- Allow missing function names in tests. -->
    <rule ref="Drupal.Commenting.FunctionComment.Missing">
        <exclude-pattern>*.Test\.php</exclude-pattern>
        <exclude-pattern>*.TestCase\.php</exclude-pattern>
        <exclude-pattern>*.test</exclude-pattern>
    </rule>
</ruleset>
