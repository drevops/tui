# Force LF line endings on every platform so checkouts are byte-identical and
# tests do not break on Windows runners, which default to autocrlf.
* text=auto eol=lf

# Keep binary assets binary so they are never line-ending normalised.
*.png binary

# Ignore files for distribution archives.

/.editorconfig   export-ignore
/.gitattributes  export-ignore
/.github         export-ignore
/.gitignore      export-ignore
/docs/assets     export-ignore
/docs/util       export-ignore
/tests           export-ignore
/phpcs.xml       export-ignore
/phpstan.neon    export-ignore
/phpunit.xml     export-ignore
/rector.php      export-ignore
